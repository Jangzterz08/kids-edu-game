// Prisma 7 — regenerate client on deploy
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id             String       @id @default(uuid())
  supabaseAuthId String       @unique
  email          String       @unique
  name           String?
  role           String       @default("parent") // parent | teacher
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  stripeCustomerId     String?   @unique
  stripeSubscriptionId String?   @unique
  subscriptionStatus   String    @default("none") // none | trialing | active | canceled | past_due
  subscriptionEnd      DateTime?
  trialEndsAt          DateTime?
  lastNudgeEmailAt     DateTime?

  kids           KidProfile[]
  classrooms     Classroom[]
}

model KidProfile {
  id          String   @id @default(uuid())
  parentId    String
  parent      User     @relation(fields: [parentId], references: [id], onDelete: Cascade)
  name        String
  avatarId    String   @default("bear")
  ageGroup    String?
  pin         String?  // bcrypt hash of 4-6 digit PIN for kid direct login
  totalStars       Int       @default(0)
  currentStreak    Int       @default(0)
  lastActivityDate DateTime?
  coins            Int       @default(0)
  unlockedItems    String    @default("[]")
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  progress           LessonProgress[]
  achievements       Achievement[]
  moduleDifficulties ModuleDifficulty[]
  reviewSchedules    ReviewSchedule[]
  dailyChallenges    DailyChallenge[]
  classrooms         ClassroomStudent[]
}

model Module {
  id        String   @id @default(uuid())
  slug      String   @unique
  title     String
  iconEmoji String
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())

  lessons   Lesson[]
}

model Lesson {
  id        String   @id @default(uuid())
  moduleId  String
  module    Module   @relation(fields: [moduleId], references: [id], onDelete: Cascade)
  slug      String
  title     String
  word      String
  imageFile String
  audioFile String
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())

  progress        LessonProgress[]
  reviewSchedules ReviewSchedule[]

  @@unique([moduleId, slug])
}

model LessonProgress {
  id          String     @id @default(uuid())
  kidId       String
  kid         KidProfile @relation(fields: [kidId], references: [id], onDelete: Cascade)
  lessonId    String
  lesson      Lesson     @relation(fields: [lessonId], references: [id], onDelete: Cascade)

  viewed         Boolean    @default(false)
  matchScore     Int?
  traceScore     Int?
  quizScore      Int?
  spellingScore  Int?
  phonicsScore   Int?
  patternScore   Int?
  oddOneOutScore Int?
  scrambleScore  Int?
  difficultyLevel String   @default("medium") // easy | medium | hard
  starsEarned    Int       @default(0)
  completedAt    DateTime?
  attempts       Int       @default(0)

  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  @@unique([kidId, lessonId])
}

model Achievement {
  id         String     @id @default(uuid())
  kidId      String
  kid        KidProfile @relation(fields: [kidId], references: [id], onDelete: Cascade)
  type       String
  moduleSlug String?
  label      String
  iconEmoji  String
  earnedAt   DateTime   @default(now())

  @@unique([kidId, type, moduleSlug])
}

model ModuleDifficulty {
  id         String     @id @default(uuid())
  kidId      String
  kid        KidProfile @relation(fields: [kidId], references: [id], onDelete: Cascade)
  moduleSlug String
  level      String     @default("medium") // easy | medium | hard
  accuracy   Float      @default(0)
  updatedAt  DateTime   @updatedAt

  @@unique([kidId, moduleSlug])
}

model ReviewSchedule {
  id             String     @id @default(uuid())
  kidId          String
  kid            KidProfile @relation(fields: [kidId], references: [id], onDelete: Cascade)
  lessonId       String
  lesson         Lesson     @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  dueDate        DateTime
  interval       Int        @default(1)
  easeFactor     Float      @default(2.5)
  reviewCount    Int        @default(0)
  lastReviewedAt DateTime?
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt

  @@unique([kidId, lessonId])
}

model DailyChallenge {
  id          String     @id @default(uuid())
  kidId       String
  kid         KidProfile @relation(fields: [kidId], references: [id], onDelete: Cascade)
  date        DateTime   @db.Date
  moduleSlug  String
  gameType    String
  score       Int?
  coinsEarned Int        @default(0)
  completedAt DateTime?
  createdAt   DateTime   @default(now())

  @@unique([kidId, date])
}

model Classroom {
  id        String   @id @default(uuid())
  teacherId String
  teacher   User     @relation(fields: [teacherId], references: [id], onDelete: Cascade)
  name      String
  joinCode  String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  students  ClassroomStudent[]
}

model ClassroomStudent {
  id          String     @id @default(uuid())
  classroomId String
  classroom   Classroom  @relation(fields: [classroomId], references: [id], onDelete: Cascade)
  kidId       String
  kid         KidProfile @relation(fields: [kidId], references: [id], onDelete: Cascade)
  joinedAt    DateTime   @default(now())

  @@unique([classroomId, kidId])
}
